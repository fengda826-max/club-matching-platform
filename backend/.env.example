# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001
# Allow any localhost port for development since Vite may auto-switch ports
CORS_ORIGIN=http://localhost:517*,https://localhost:517*

# AI Configuration
# Choose: anthropic or openai-compat
AI_PROVIDER=openai-compat
AI_API_KEY=your_api_key_here
# For 火山引擎 字节方舟 (default):
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
AI_MODEL=ark-code-latest
# For Anthropic native:
# AI_BASE_URL=https://api.anthropic.com
# AI_MODEL=claude-3-7-sonnet-20250219
AI_TIMEOUT=30000
AI_MAX_RETRIES=2
NODE_ENV=production
